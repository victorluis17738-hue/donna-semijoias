# Copie para .env (o .env fica fora do Git) e ajuste os valores.

PORT=3000
NODE_ENV=development

# Segurança (troque em produção!)
SESSION_SECRET=troque-por-uma-chave-grande-e-aleatoria
ADMIN_EMAIL=admin@donna.local
ADMIN_PASSWORD=troque-esta-senha

# Número que recebe os pedidos do carrinho (só dígitos: 55 + DDD + número)
STORE_WHATSAPP=5599999999999

# Banco de dados:
# - LOCAL: deixe DATABASE_URL vazio -> o app usa PGlite (Postgres em processo, pasta ./pgdata).
# - PRODUÇÃO (Render + Supabase): cole aqui a connection string do Supabase (Session pooler).
#   Ex.: postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:5432/postgres
DATABASE_URL=
